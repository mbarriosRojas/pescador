{
  "name": "pescador-task-manager",
  "version": "1.0.0",
  "description": "CLI tool for managing tasks and user stories in the Pescador project",
  "main": "dist/cli.js",
  "type": "module",
  "bin": {
    "task": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "task": "tsx src/cli.ts",
    "validate": "tsx src/cli.ts validate",
    "create": "tsx src/cli.ts create",
    "list": "tsx src/cli.ts list",
    "update": "tsx src/cli.ts update",
    "pr": "tsx src/cli.ts pr"
  },
  "keywords": [
    "task-management",
    "user-stories",
    "github",
    "automation"
  ],
  "author": "Pescador Team",
  "license": "MIT",
  "dependencies": {
    "@octokit/rest": "^20.0.2",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "inquirer": "^9.2.12",
    "js-yaml": "^4.1.0",
    "date-fns": "^3.0.6"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
