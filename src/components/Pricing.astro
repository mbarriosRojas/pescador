---

<section id="precios" class="section pricing">
  <div class="container">
    <div class="section-header">
      <h2>Planes y Precios</h2>
      <p>Elige el plan que mejor se adapte a tus necesidades</p>
    </div>

    <div class="pricing-grid">
      <article class="pricing-card">
        <div class="pricing-header">
          <h3>Básico</h3>
          <div class="price">
            <span class="currency">$</span>
            <span class="amount">19</span>
            <span class="period">/mes</span>
          </div>
        </div>
        <ul class="features">
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            3 consultas al mes
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Consulta general
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Recetas digitales
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Historial médico
          </li>
          <li class="disabled">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 4l12 12M16 4L4 16" stroke="#cccccc" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Especialistas
          </li>
        </ul>
        <a href="#contacto" class="btn btn-outline">Seleccionar Plan</a>
      </article>

      <article class="pricing-card featured">
        <div class="popular-badge">Más Popular</div>
        <div class="pricing-header">
          <h3>Premium</h3>
          <div class="price">
            <span class="currency">$</span>
            <span class="amount">49</span>
            <span class="period">/mes</span>
          </div>
        </div>
        <ul class="features">
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Consultas ilimitadas
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Acceso a especialistas
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Atención prioritaria
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Seguimiento personalizado
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Planes de bienestar
          </li>
        </ul>
        <a href="#contacto" class="btn btn-primary">Seleccionar Plan</a>
      </article>

      <article class="pricing-card">
        <div class="pricing-header">
          <h3>Familiar</h3>
          <div class="price">
            <span class="currency">$</span>
            <span class="amount">89</span>
            <span class="period">/mes</span>
          </div>
        </div>
        <ul class="features">
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Hasta 5 miembros
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Consultas ilimitadas
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Todos los especialistas
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Atención pediátrica
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Descuentos en farmacias
          </li>
        </ul>
        <a href="#contacto" class="btn btn-outline">Seleccionar Plan</a>
      </article>
    </div>

    <div class="pricing-note">
      <p>Todos los planes incluyen prueba gratuita de 7 días. Cancela cuando quieras, sin compromisos.</p>
    </div>
  </div>
</section>

<style>
  .pricing {
    background: linear-gradient(135deg, var(--bg-light) 0%, var(--bg-white) 100%);
  }

  [data-theme="dark"] .pricing {
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }

  .section-header h2 {
    color: var(--text-dark);
  }

  .section-header p {
    font-size: 1.125rem;
    color: var(--text-light);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-lg);
  }

  .pricing-card {
    background-color: var(--bg-white);
    border-radius: 16px;
    padding: var(--spacing-lg);
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
    border: 2px solid var(--border-color);
    position: relative;
  }

  .pricing-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  .pricing-card.featured {
    border-color: var(--primary-color);
    box-shadow: var(--shadow-md);
  }

  .popular-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    color: var(--text-white);
    padding: 0.5rem 1.5rem;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .pricing-header {
    text-align: center;
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-md);
    border-bottom: 2px solid var(--border-color);
  }

  .pricing-header h3 {
    color: var(--text-dark);
    font-size: 1.5rem;
    margin-bottom: var(--spacing-sm);
  }

  .price {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0.25rem;
  }

  .currency {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--primary-color);
    margin-top: 0.5rem;
  }

  .amount {
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--text-dark);
    line-height: 1;
  }

  .period {
    font-size: 1rem;
    color: var(--text-light);
    align-self: flex-end;
    margin-bottom: 0.5rem;
  }

  .features {
    list-style: none;
    margin-bottom: var(--spacing-lg);
  }

  .features li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0;
    color: var(--text-dark);
  }

  .features li.disabled {
    color: var(--text-light);
    opacity: 0.5;
  }

  .pricing-card .btn {
    width: 100%;
  }

  .pricing-note {
    text-align: center;
    color: var(--text-light);
    font-size: 0.9rem;
    padding-top: var(--spacing-md);
  }

  @media (max-width: 768px) {
    .pricing-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
