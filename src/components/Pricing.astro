---
---

<section id="precios" class="section pricing">
  <div class="container">
    <div class="section-header">
      <h2>Planes y Precios</h2>
      <p>Elige el plan que mejor se adapte a tus necesidades</p>
    </div>

    <div class="pricing-grid">
      <article class="pricing-card">
        <div class="pricing-header">
          <h3>Básico</h3>
          <div class="price">
            <span class="currency">$</span>
            <span class="amount">19</span>
            <span class="period">/mes</span>
          </div>
        </div>
        <ul class="features">
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            3 consultas al mes
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Consulta general
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Recetas digitales
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Historial médico
          </li>
          <li class="disabled">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 4l12 12M16 4L4 16" stroke="#cccccc" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Especialistas
          </li>
        </ul>
        <a href="#contacto" class="btn btn-outline">Seleccionar Plan</a>
      </article>

      <article class="pricing-card featured">
        <div class="popular-badge">Más Popular</div>
        <div class="pricing-header">
          <h3>Premium</h3>
          <div class="price">
            <span class="currency">$</span>
            <span class="amount">49</span>
            <span class="period">/mes</span>
          </div>
        </div>
        <ul class="features">
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Consultas ilimitadas
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Acceso a especialistas
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Atención prioritaria
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Seguimiento personalizado
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Planes de bienestar
          </li>
        </ul>
        <a href="#contacto" class="btn btn-primary">Seleccionar Plan</a>
      </article>

      <article class="pricing-card">
        <div class="pricing-header">
          <h3>Familiar</h3>
          <div class="price">
            <span class="currency">$</span>
            <span class="amount">89</span>
            <span class="period">/mes</span>
          </div>
        </div>
        <ul class="features">
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Hasta 5 miembros
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Consultas ilimitadas
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Todos los especialistas
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Atención pediátrica
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10l4 4 8-8" stroke="#00c896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Descuentos en farmacias
          </li>
        </ul>
        <a href="#contacto" class="btn btn-outline">Seleccionar Plan</a>
      </article>
    </div>

    <div class="pricing-note">
      <p>Todos los planes incluyen prueba gratuita de 7 días. Cancela cuando quieras, sin compromisos.</p>
    </div>
  </div>
</section>

<style>
  .pricing {
    background-color: var(--color-white);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .section-header h2 {
    color: var(--color-text-primary);
  }

  .section-header p {
    font-size: var(--font-size-md);
    color: var(--color-text-secondary);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--gap-md);
    margin-bottom: var(--space-8);
  }

  .pricing-card {
    background-color: var(--color-white);
    border-radius: var(--border-radius-md);
    padding: var(--space-8);
    border: var(--border-width-thin) solid var(--border-color-light);
    transition: var(--transition-border);
    position: relative;
  }

  .pricing-card:hover {
    border-color: var(--color-primary);
  }

  .pricing-card.featured {
    border-color: var(--color-accent);
    border-width: 2px;
  }

  .popular-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--color-accent);
    color: var(--color-white);
    padding: var(--space-1) var(--space-4);
    border-radius: var(--border-radius-sm);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
  }

  .pricing-header {
    text-align: center;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-5);
    border-bottom: var(--border-width-thin) solid var(--border-color-light);
  }

  .pricing-header h3 {
    color: var(--color-text-primary);
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-semibold);
    margin-bottom: var(--space-4);
  }

  .price {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0.25rem;
  }

  .currency {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-primary);
    margin-top: 0.5rem;
  }

  .amount {
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    line-height: 1;
  }

  .period {
    font-size: var(--font-size-base);
    color: var(--color-text-tertiary);
    align-self: flex-end;
    margin-bottom: 0.5rem;
  }

  .features {
    list-style: none;
    margin-bottom: var(--space-8);
  }

  .features li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) 0;
    color: var(--color-text-secondary);
    font-size: var(--font-size-base);
  }

  .features li.disabled {
    color: var(--color-text-tertiary);
    opacity: 0.5;
  }

  .pricing-card .btn {
    width: 100%;
  }

  .pricing-note {
    text-align: center;
    color: var(--color-text-tertiary);
    font-size: var(--font-size-sm);
    padding-top: var(--space-5);
    line-height: var(--line-height-relaxed);
  }

  @media (max-width: 768px) {
    .pricing-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
