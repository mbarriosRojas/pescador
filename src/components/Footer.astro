<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-section">
        <h3>Médico Online</h3>
        <p>Tu salud al alcance de un clic. Consultas médicas profesionales desde la comodidad de tu hogar.</p>
        <div class="social-links">
          <a href="#" aria-label="Facebook">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href="#" aria-label="Twitter">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/>
            </svg>
          </a>
          <a href="#" aria-label="Instagram">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
        </div>
      </div>
      
      <div class="footer-section">
        <h4>Servicios</h4>
        <ul>
          <li><a href="#servicios">Consulta General</a></li>
          <li><a href="#servicios">Especialidades</a></li>
          <li><a href="#servicios">Recetas Médicas</a></li>
          <li><a href="#servicios">Seguimiento</a></li>
        </ul>
      </div>
      
      <div class="footer-section">
        <h4>Información</h4>
        <ul>
          <li><a href="#como-funciona">Cómo Funciona</a></li>
          <li><a href="#precios">Precios</a></li>
          <li><a href="#">Términos y Condiciones</a></li>
          <li><a href="#">Política de Privacidad</a></li>
          <li><a href="tasks/" style="color: #26d9a3; font-weight: 600;">📋 Task Dashboard</a></li>
        </ul>
      </div>
      
      <div class="footer-section">
        <h4>Contacto</h4>
        <ul>
          <li>Email: info@medicoonline.com</li>
          <li>Teléfono: +1 (555) 123-4567</li>
          <li>Disponible 24/7</li>
        </ul>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p>&copy; 2026 Médico Online. Todos los derechos reservados.</p>
      <p style="margin-top: 0.5rem; font-size: 0.875rem;">Powered by <a href="https://github.com/mbarriosRojas/pescador" target="_blank" style="color: #26d9a3;">Pescador Task Management</a></p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--bg-secondary);
    color: var(--text-white);
    padding: var(--spacing-xl) 0 var(--spacing-md);
    border-top: 1px solid var(--border-subtle);
  }

  .footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-lg);
  }

  .footer-section h3 {
    color: var(--text-white);
    margin-bottom: var(--spacing-sm);
  }

  .footer-section h4 {
    color: var(--text-white);
    margin-bottom: var(--spacing-sm);
    font-size: 1.1rem;
  }

  .footer-section p {
    color: var(--text-secondary);
    margin-bottom: var(--spacing-sm);
  }

  .footer-section ul {
    list-style: none;
  }

  .footer-section ul li {
    margin-bottom: 0.5rem;
    color: var(--text-secondary);
  }

  .footer-section ul li a {
    color: var(--text-secondary);
    transition: var(--transition);
  }

  .footer-section ul li a:hover {
    color: var(--secondary-color);
  }

  .social-links {
    display: flex;
    gap: 1rem;
    margin-top: var(--spacing-sm);
  }

  .social-links a {
    color: var(--text-white);
    transition: var(--transition);
  }

  .social-links a:hover {
    color: var(--secondary-color);
    transform: translateY(-2px);
  }

  .footer-bottom {
    border-top: 1px solid var(--border-subtle);
    padding-top: var(--spacing-md);
    text-align: center;
    color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: var(--spacing-md);
    }
  }
</style>
