---

<section id="inicio" class="hero">
  <div class="container">
    <div class="hero-content">
      <div class="hero-text">
        <h1>Tu Salud, Nuestra Prioridad</h1>
        <p class="hero-subtitle">
          Consultas médicas profesionales desde la comodidad de tu hogar. 
          Conecta con médicos certificados en minutos, 24/7.
        </p>
        <div class="hero-buttons">
          <a href="#contacto" class="btn btn-primary">Agendar Consulta</a>
          <a href="#como-funciona" class="btn btn-outline">Cómo Funciona</a>
        </div>
        <div class="hero-stats">
          <div class="stat">
            <strong>10,000+</strong>
            <span>Pacientes Atendidos</span>
          </div>
          <div class="stat">
            <strong>500+</strong>
            <span>Médicos Certificados</span>
          </div>
          <div class="stat">
            <strong>24/7</strong>
            <span>Disponibilidad</span>
          </div>
        </div>
      </div>
      <div class="hero-image">
        <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
          <circle cx="200" cy="200" r="160" fill="#f5f5f5"/>
          <rect x="120" y="120" width="160" height="160" rx="4" fill="#2c3e50"/>
          <path d="M200 150 L200 250 M150 200 L250 200" stroke="white" stroke-width="12" stroke-linecap="round"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: var(--color-white);
    padding: var(--spacing-section) 0;
    min-height: calc(100vh - 80px);
    display: flex;
    align-items: center;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--gap-lg);
    align-items: center;
  }

  .hero-text h1 {
    color: var(--color-text-primary);
    margin-bottom: var(--space-6);
  }

  .hero-subtitle {
    font-size: var(--font-size-md);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
    line-height: var(--line-height-relaxed);
    max-width: var(--max-width-text);
  }

  .hero-buttons {
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-10);
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    padding-top: var(--space-8);
    border-top: var(--border-width-thin) solid var(--border-color-light);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .stat strong {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-primary);
    line-height: var(--line-height-tight);
  }

  .stat span {
    font-size: var(--font-size-sm);
    color: var(--color-text-tertiary);
    line-height: var(--line-height-normal);
  }

  .hero-image {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-image svg {
    width: 100%;
    max-width: 400px;
    height: auto;
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--space-10) 0;
      min-height: auto;
    }

    .hero-content {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .hero-image {
      order: -1;
    }

    .hero-image svg {
      max-width: 280px;
    }

    .hero-stats {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }
</style>
