# Entorno
NODE_ENV=development

# Puerto del servidor
PORT=5000

# MongoDB
# Para desarrollo local: mongodb://localhost:27017/taxi-admin
# Para MongoDB Atlas: mongodb+srv://usuario:password@cluster.mongodb.net/taxi-admin
MONGODB_URI=mongodb://localhost:27017/taxi-admin

# JWT Secrets (¡IMPORTANTE! Cambiar en producción)
JWT_SECRET=tu-secret-key-super-segura-aqui-cambiar-en-produccion
JWT_REFRESH_SECRET=tu-refresh-secret-key-aqui-cambiar-en-produccion

# JWT Expiración
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Bcrypt
BCRYPT_ROUNDS=10

# CORS
CORS_ORIGIN=http://localhost:3000
